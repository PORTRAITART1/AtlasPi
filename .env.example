# AtlasPi Environment Configuration
# COPY TO .env.local AND FILL IN YOUR VALUES

# ============================================================
# PI NETWORK CONFIGURATION (CRITICAL - GET FROM PI DEVELOPER PORTAL)
# ============================================================

# Server API Key (KEEP SECRET - Backend only!)
# Get from: https://developers.pi-network.dev → Your App → Settings
PI_SERVER_API_KEY=your_server_api_key_here_keep_secret

# Network: testnet or mainnet
# Use testnet for testing (0.1 Pi minimum)
PI_NETWORK=testnet

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================

# Node environment
NODE_ENV=development
PORT=3001

# API endpoints
VITE_API_BASE=http://localhost:3001
VITE_PI_API=https://api-testnet.minepi.com

# Pi App configuration
VITE_APP_ID=your_pi_app_id_here

# ============================================================
# FRONTEND CONFIGURATION (Render deployment)
# ============================================================

# Render frontend URL
VITE_FRONTEND_URL=https://atlaspi-fronted.onrender.com
VITE_BACKEND_URL=https://atlaspi-backend.onrender.com

# ============================================================
# LOGGING
# ============================================================

LOG_LEVEL=info
LOG_FILE=/var/log/atlaspi/backend.log

# ============================================================
# SECURITY
# ============================================================

# CORS allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://atlaspi-fronted.onrender.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# DATABASE (Optional - for production)
# ============================================================

DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atlaspi
DB_USER=atlaspi
DB_PASSWORD=

# ============================================================
# PAYMENT STORAGE (Optional)
# ============================================================

# Store payment receipts
STORE_PAYMENTS=true
PAYMENTS_DB_PATH=/var/lib/atlaspi/payments.db
