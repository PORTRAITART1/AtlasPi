# ============================================================================
# Production Security & Monitoring
# ============================================================================
LOG_LEVEL=info
DEBUG_MODE=false

# HTTPS/TLS (configure with reverse proxy or app-level)
FORCE_HTTPS=true

# Rate limiting (stricter in production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# Payment security (will be configured in DAY 3)
PAYMENT_VERIFICATION_REQUIRED=true
PAYMENT_WEBHOOK_TIMEOUT_SECONDS=30

