NODE_ENV=production
PORT=3000

# Frontend URLs for CORS whitelist (SET TO YOUR PRODUCTION DOMAIN)
FRONTEND_URL=https://atlaspi.example.com
# FRONTEND_APP_URL=https://app.atlaspi.example.com

# Admin Secret for moderation protection (MUST BE STRONG AND UNIQUE)
# Generate with: openssl rand -base64 32
ADMIN_SECRET=CHANGE_ME_STRONG_PRODUCTION_SECRET_HERE

