# Set MODE to 'pirc2-production' to activate production flows
APP_MODE=pirc2-production

# Pi API Production Configuration (PLACEHOLDERS - not yet integrated)
# TODO[PIRC2-DAY2]: Get actual production credentials from Pi Network
# TODO[PIRC2-DAY2]: Document production API endpoints
